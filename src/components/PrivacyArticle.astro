---
import { getEntry, render } from 'astro:content';
import { strings, type Locale } from '../i18n/strings';
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = strings[locale];

const entry = await getEntry('privacy', locale);
if (!entry) throw new Error(`Missing privacy entry for locale "${locale}"`);
const { Content } = await render(entry);

const siteOrigin = 'https://alarm.tokugai.com';
const pagePath = locale === 'en' ? '/privacy/' : `/${locale}/privacy/`;
const canonicalUrl = `${siteOrigin}${pagePath}`;
const toolPath = locale === 'en' ? '/' : `/${locale}/`;

const webPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': canonicalUrl,
  name: entry.data.title,
  url: canonicalUrl,
  description: t.privacyPageMetaDescription,
  inLanguage: t.htmlLang,
  dateModified: entry.data.lastUpdated,
  isPartOf: {
    '@type': 'WebSite',
    name: t.title,
    url: `${siteOrigin}${toolPath}`,
  },
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: t.title, item: `${siteOrigin}${toolPath}` },
      { '@type': 'ListItem', position: 2, name: entry.data.title, item: canonicalUrl },
    ],
  },
};
---
<BaseLayout
  locale={locale}
  pagePath={pagePath}
  pageTitle={t.privacyPageTitle}
  pageDescription={t.privacyPageMetaDescription}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(webPageJsonLd)} />
  </Fragment>

  <main class="app prose-page">
    <article class="prose">
      <h1>{entry.data.title}</h1>
      <p class="page-meta">
        <span>{t.privacyLastUpdatedLabel}: </span>
        <time datetime={entry.data.lastUpdated}>{entry.data.lastUpdated}</time>
      </p>

      <Content />

      <p class="back-link">
        <a href={toolPath}>{t.privacyBackToTool}</a>
      </p>
    </article>
  </main>
</BaseLayout>
