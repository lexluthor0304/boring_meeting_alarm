---
import { locales, strings, type Locale } from '../i18n/strings';
import { pathForLocale } from '../i18n/locale';

interface Props {
  current: Locale;
}

const { current } = Astro.props;

const labels: Record<Locale, string> = {
  en: 'English',
  zh: '中文',
  ja: '日本語',
};
---
<nav class="language-switcher" aria-label={strings[current].languageSwitcherLabel}>
  {locales.map((loc) => (
    <a
      href={pathForLocale(loc)}
      hreflang={strings[loc].htmlLang}
      lang={strings[loc].htmlLang}
      class:list={['lang-link', { 'is-current': loc === current }]}
      aria-current={loc === current ? 'page' : undefined}
      data-locale={loc}
    >
      {labels[loc]}
    </a>
  ))}
</nav>
