---
import { render, type CollectionEntry } from 'astro:content';
import { strings, type Locale } from '../i18n/strings';
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  locale: Locale;
  entry: CollectionEntry<'blog'>;
}

const { locale, entry } = Astro.props;
const t = strings[locale];
const { Content } = await render(entry);

const siteOrigin = 'https://alarm.tokugai.com';
const blogIndexPath = locale === 'en' ? '/blog/' : `/${locale}/blog/`;
const pagePath = locale === 'en' ? `/blog/${entry.data.slug}/` : `/${locale}/blog/${entry.data.slug}/`;
const canonicalUrl = `${siteOrigin}${pagePath}`;
const toolPath = locale === 'en' ? '/' : `/${locale}/`;

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  '@id': canonicalUrl,
  headline: entry.data.title,
  description: entry.data.description,
  url: canonicalUrl,
  inLanguage: t.htmlLang,
  datePublished: entry.data.datePublished,
  dateModified: entry.data.dateModified ?? entry.data.datePublished,
  author: { '@type': 'Person', name: entry.data.author },
  publisher: {
    '@type': 'Organization',
    name: 'Boring Meeting Alarm',
    url: `${siteOrigin}${toolPath}`,
  },
  keywords: entry.data.tags.join(', '),
  isPartOf: {
    '@type': 'Blog',
    name: t.blogIndexTitle,
    url: `${siteOrigin}${blogIndexPath}`,
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t.title, item: `${siteOrigin}${toolPath}` },
    { '@type': 'ListItem', position: 2, name: t.blogIndexTitle, item: `${siteOrigin}${blogIndexPath}` },
    { '@type': 'ListItem', position: 3, name: entry.data.title, item: canonicalUrl },
  ],
};
---
<BaseLayout
  locale={locale}
  pagePath={pagePath}
  pageTitle={`${entry.data.title} — ${t.title}`}
  pageDescription={entry.data.description}
>
  <Fragment slot="head">
    <meta property="article:published_time" content={entry.data.datePublished} />
    {entry.data.dateModified && (
      <meta property="article:modified_time" content={entry.data.dateModified} />
    )}
    {entry.data.tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}
    <script is:inline type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  </Fragment>

  <main class="app prose-page">
    <article class="prose">
      <h1>{entry.data.title}</h1>
      <p class="page-meta">
        <span>{t.blogPublishedLabel}: </span>
        <time datetime={entry.data.datePublished}>{entry.data.datePublished}</time>
        {entry.data.dateModified && entry.data.dateModified !== entry.data.datePublished && (
          <>
            <span aria-hidden="true"> · </span>
            <span>{t.blogUpdatedLabel}: </span>
            <time datetime={entry.data.dateModified}>{entry.data.dateModified}</time>
          </>
        )}
      </p>

      <p class="post-description">{entry.data.description}</p>

      <Content />

      <p class="back-link">
        <a href={blogIndexPath}>{t.blogBackToIndex}</a>
      </p>
    </article>
  </main>
</BaseLayout>
