---
import { strings, type Locale } from '../i18n/strings';
import BaseLayout from '../layouts/BaseLayout.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = strings[locale];

const siteOrigin = 'https://alarm.tokugai.com';
const repoUrl = 'https://github.com/lexluthor0304/boring_meeting_alarm';
const lastUpdated = '2026-05-13';
const canonicalUrl = `${siteOrigin}${locale === 'en' ? '/' : `/${locale}/`}`;

const softwareJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: t.title,
  url: canonicalUrl,
  description: t.intro,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Web (Chromium-based browsers)',
  browserRequirements: 'Requires getDisplayMedia and Web Audio API (Chrome 91+, Edge 91+).',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  creator: { '@type': 'Person', name: 'tokugai' },
  inLanguage: ['en', 'zh-CN', 'ja'],
  sameAs: [repoUrl],
  dateModified: lastUpdated,
};

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: t.htmlLang,
  mainEntity: t.faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};

const howToJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  inLanguage: t.htmlLang,
  name: `${t.instructionsTitle} — ${t.title}`,
  description: t.intro,
  totalTime: 'PT1M',
  step: [t.instruction1, t.instruction2, t.instruction3].map((text, idx) => ({
    '@type': 'HowToStep',
    position: idx + 1,
    text,
  })),
};
---
<BaseLayout locale={locale} pagePath="/">
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(softwareJsonLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(howToJsonLd)} />
  </Fragment>

  <main class="app">
    <p class="intro">{t.intro}</p>

    <section class="status-card" aria-live="polite">
      <div class="status-row">
        <span class="status-dot" data-status-dot></span>
        <span class="status-label" data-status-label>{t.statusIdle}</span>
      </div>

      <div class="volume-row">
        <span class="volume-caption">{t.currentVolume}</span>
        <div class="volume-bar" aria-hidden="true">
          <div class="volume-bar-fill" data-volume-fill></div>
          <div class="volume-bar-threshold" data-volume-threshold></div>
        </div>
        <span class="volume-readout" data-volume-readout>—</span>
      </div>
    </section>

    <section class="settings-card">
      <label class="field" for="bma-duration">
        <span class="field-label">{t.silenceDurationLabel}</span>
        <span class="field-control">
          <input id="bma-duration" name="bma-duration" type="number" data-input-duration min="5" max="3600" step="1" />
          <span class="field-unit">{t.seconds}</span>
        </span>
      </label>

      <label class="field" for="bma-threshold">
        <span class="field-label">
          {t.thresholdLabel}
          <span class="field-value" data-threshold-readout>—</span>
        </span>
        <input id="bma-threshold" name="bma-threshold" type="range" data-input-threshold min="-80" max="-20" step="1" class="range-input" />
        <span class="field-hint">{t.thresholdHint}</span>
      </label>

      <label class="checkbox" for="bma-alarm-sound">
        <input id="bma-alarm-sound" name="bma-alarm-sound" type="checkbox" data-input-alarm-sound />
        <span>{t.playAlarmSound}</span>
      </label>

      <label class="checkbox" for="bma-notification">
        <input id="bma-notification" name="bma-notification" type="checkbox" data-input-notification />
        <span>{t.enableNotification}</span>
      </label>
    </section>

    <section class="action-row">
      <button type="button" class="primary" data-action-start>{t.startMonitoring}</button>
      <button type="button" class="secondary" data-action-stop hidden>{t.stopMonitoring}</button>
    </section>

    <p class="error-message" data-error hidden></p>

    <section class="instructions">
      <h2>{t.instructionsTitle}</h2>
      <ol>
        <li>{t.instruction1}</li>
        <li>{t.instruction2}</li>
        <li>{t.instruction3}</li>
      </ol>
      <p class="browser-hint">{t.browserHint}</p>
    </section>

    <section class="faq">
      <h2>{t.faqTitle}</h2>
      {t.faq.map((item) => (
        <article class="faq-item">
          <h3>{item.q}</h3>
          <p>{item.a}</p>
        </article>
      ))}
    </section>
  </main>

  <Fragment slot="end">
    <div class="modal" data-modal hidden role="alertdialog" aria-modal="true" aria-labelledby="modal-title">
      <div class="modal-content">
        <h2 id="modal-title" data-modal-title></h2>
        <p data-modal-body></p>
        <button type="button" class="primary" data-modal-dismiss></button>
      </div>
    </div>

    <script>
      import { loadSettings, saveSettings, SETTINGS_LIMITS } from '../lib/settings';
      import { SilenceDetector } from '../lib/silence-detector';
      import { AlertManager, requestNotificationPermissionIfNeeded } from '../lib/alerts';
      import { track } from '../lib/analytics';
      import type { AppSettings } from '../lib/types';

      const t = window.__BMA__.t;

      const $ = <T extends HTMLElement = HTMLElement>(selector: string): T => {
        const el = document.querySelector<T>(selector);
        if (!el) throw new Error(`Missing element: ${selector}`);
        return el;
      };

      const statusDot = $('[data-status-dot]');
      const statusLabel = $('[data-status-label]');
      const volumeFill = $<HTMLDivElement>('[data-volume-fill]');
      const volumeThreshold = $<HTMLDivElement>('[data-volume-threshold]');
      const volumeReadout = $('[data-volume-readout]');
      const inputDuration = $<HTMLInputElement>('[data-input-duration]');
      const inputThreshold = $<HTMLInputElement>('[data-input-threshold]');
      const thresholdReadout = $('[data-threshold-readout]');
      const inputAlarmSound = $<HTMLInputElement>('[data-input-alarm-sound]');
      const inputNotification = $<HTMLInputElement>('[data-input-notification]');
      const startBtn = $<HTMLButtonElement>('[data-action-start]');
      const stopBtn = $<HTMLButtonElement>('[data-action-stop]');
      const errorEl = $<HTMLParagraphElement>('[data-error]');
      const modal = $<HTMLDivElement>('[data-modal]');
      const modalTitle = $('[data-modal-title]');
      const modalBody = $('[data-modal-body]');
      const modalDismiss = $<HTMLButtonElement>('[data-modal-dismiss]');
      modalDismiss.textContent = t.alertDismiss;

      const settings = loadSettings();
      inputDuration.value = String(settings.silenceDurationSec);
      inputThreshold.value = String(settings.silenceThresholdDb);
      inputAlarmSound.checked = settings.alarmSoundEnabled;
      inputNotification.checked = settings.notificationEnabled;
      updateThresholdReadout(settings.silenceThresholdDb);
      updateThresholdMarker(settings.silenceThresholdDb);

      const alertManager = new AlertManager();

      let detector: SilenceDetector | null = null;
      let stream: MediaStream | null = null;
      let listeningStartedAt: number | null = null;
      let alertedAt: number | null = null;

      function clampNumber(value: number, min: number, max: number): number {
        return Math.min(Math.max(value, min), max);
      }

      function readSettings(): AppSettings {
        const duration = clampNumber(
          Number(inputDuration.value) || 30,
          SETTINGS_LIMITS.silenceDurationSec.min,
          SETTINGS_LIMITS.silenceDurationSec.max,
        );
        const threshold = clampNumber(
          Number(inputThreshold.value) || -50,
          SETTINGS_LIMITS.silenceThresholdDb.min,
          SETTINGS_LIMITS.silenceThresholdDb.max,
        );
        return {
          silenceDurationSec: duration,
          silenceThresholdDb: threshold,
          alarmSoundEnabled: inputAlarmSound.checked,
          notificationEnabled: inputNotification.checked,
        };
      }

      function persist(): void {
        saveSettings(readSettings());
      }

      function updateThresholdReadout(db: number): void {
        thresholdReadout.textContent = `${db} dB`;
      }

      function updateThresholdMarker(db: number): void {
        const pct = clampNumber(((db + 80) / 60) * 100, 0, 100);
        volumeThreshold.style.left = `${pct}%`;
      }

      function updateVolumeBar(db: number): void {
        const pct = clampNumber(((db + 80) / 60) * 100, 0, 100);
        volumeFill.style.width = `${pct}%`;
        volumeReadout.textContent = `${Math.round(db)} dB`;
      }

      function setStatus(state: 'idle' | 'listening' | 'alerted'): void {
        statusDot.dataset.state = state;
        if (state === 'idle') statusLabel.textContent = t.statusIdle;
        else if (state === 'listening') statusLabel.textContent = t.statusListening;
        else statusLabel.textContent = t.statusAlerted;
      }

      function showError(message: string): void {
        errorEl.textContent = message;
        errorEl.hidden = false;
      }

      function clearError(): void {
        errorEl.textContent = '';
        errorEl.hidden = true;
      }

      function stopMonitoring(reason: 'user_clicked' | 'track_ended'): void {
        if (!detector && !stream) return;
        const wasFor = listeningStartedAt ? Math.round((Date.now() - listeningStartedAt) / 1000) : 0;
        detector?.stop();
        detector = null;
        stream?.getTracks().forEach((track) => track.stop());
        stream = null;
        listeningStartedAt = null;
        setStatus('idle');
        updateVolumeBar(-80);
        startBtn.hidden = false;
        stopBtn.hidden = true;
        if (reason === 'user_clicked') {
          track('stop_monitoring', { reason });
        } else {
          track('screen_share_track_ended', { was_monitoring_for_sec: wasFor });
        }
      }

      async function startMonitoring(): Promise<void> {
        clearError();
        const cfg = readSettings();
        persist();

        if (typeof navigator === 'undefined' || !navigator.mediaDevices?.getDisplayMedia) {
          showError(t.errorUnsupportedBrowser);
          return;
        }

        const notificationsAllowed = await requestNotificationPermissionIfNeeded(cfg.notificationEnabled);

        let media: MediaStream;
        try {
          media = await navigator.mediaDevices.getDisplayMedia({
            video: { displaySurface: 'browser' },
            audio: true,
            // @ts-expect-error - non-standard but widely supported in Chromium
            selfBrowserSurface: 'exclude',
            systemAudio: 'include',
            preferCurrentTab: false,
          });
        } catch (err) {
          if (err instanceof DOMException && err.name === 'NotAllowedError') {
            track('screen_share_cancelled');
            showError(t.errorPermissionDenied);
          } else {
            showError(t.errorGeneric);
          }
          return;
        }

        const audioTracks = media.getAudioTracks();
        if (audioTracks.length === 0) {
          media.getTracks().forEach((track) => track.stop());
          track('no_audio_track');
          showError(t.errorNoAudioTrack);
          return;
        }
        media.getVideoTracks().forEach((track) => track.stop());

        stream = new MediaStream(audioTracks);
        listeningStartedAt = Date.now();
        const firstAudioTrack = audioTracks[0]!;
        firstAudioTrack.onended = () => stopMonitoring('track_ended');

        detector = new SilenceDetector({
          stream,
          thresholdDb: cfg.silenceThresholdDb,
          durationSec: cfg.silenceDurationSec,
          onLevel: (db) => updateVolumeBar(db),
          onSilenceDetected: () => onSilenceDetected(cfg, notificationsAllowed),
        });
        detector.start();

        setStatus('listening');
        startBtn.hidden = true;
        stopBtn.hidden = false;

        track('start_monitoring', {
          silence_duration_sec: cfg.silenceDurationSec,
          silence_threshold_db: cfg.silenceThresholdDb,
          alarm_sound_enabled: cfg.alarmSoundEnabled,
          notification_enabled: cfg.notificationEnabled,
        });
      }

      function onSilenceDetected(cfg: AppSettings, notificationsAllowed: boolean): void {
        setStatus('alerted');
        alertedAt = Date.now();
        track('silence_detected', { silence_duration_sec: cfg.silenceDurationSec });
        alertManager.trigger({
          modal,
          modalTitle,
          modalBody,
          notificationEnabled: cfg.notificationEnabled && notificationsAllowed,
          alarmSoundEnabled: cfg.alarmSoundEnabled,
        });
      }

      function dismissAlert(): void {
        const secondsToDismiss = alertedAt ? Math.round((Date.now() - alertedAt) / 1000) : 0;
        alertedAt = null;
        alertManager.dismiss({ modal });
        stopMonitoring('user_clicked');
        track('silence_alert_dismissed', { seconds_to_dismiss: secondsToDismiss });
      }

      startBtn.addEventListener('click', () => {
        void startMonitoring();
      });
      stopBtn.addEventListener('click', () => stopMonitoring('user_clicked'));
      modalDismiss.addEventListener('click', dismissAlert);

      inputDuration.addEventListener('change', persist);
      inputThreshold.addEventListener('input', () => {
        const db = Number(inputThreshold.value);
        updateThresholdReadout(db);
        updateThresholdMarker(db);
      });
      inputThreshold.addEventListener('change', persist);
      inputAlarmSound.addEventListener('change', persist);
      inputNotification.addEventListener('change', persist);

      setStatus('idle');
      updateVolumeBar(-80);

      if (typeof navigator !== 'undefined' && !navigator.mediaDevices?.getDisplayMedia) {
        showError(t.errorUnsupportedBrowser);
        startBtn.disabled = true;
      }
    </script>
  </Fragment>
</BaseLayout>
